---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';

// PLACEHOLDER icons — the existing white line-icon PNGs, recoloured via CSS
// mask (gold on white bands, white on gold tiles). Swap each `icon` for the
// real line-icon set when the client supplies it.
const ic = {
  construction: '/home/home-icon-construction.png',
  bridge: '/home/home-icon-bridge.png',
  cmhc: '/home/home-icon-cmhc.png',
  retail: '/home/home-icon-retail.png',
  office: '/home/home-icon-office.png',
  student: '/home/home-icon-student.png',
};

const services = [
  { icon: ic.construction, name: 'Construction Loan', desc: 'Funding to build, structured to draw down with your timeline.' },
  { icon: ic.office, name: 'Land & Development Loan', desc: 'Capital to acquire and entitle, before the first shovel hits the ground.' },
  { icon: ic.retail, name: 'Standard Conventional Term', desc: 'Long-term financing on stabilized, income-producing assets.' },
  { icon: ic.bridge, name: 'Bridge Financing', desc: 'Fast, flexible capital to close the gap and keep momentum.' },
  { icon: ic.cmhc, name: 'CMHC Insured & Construction', desc: 'Lower rates and higher leverage through insured multifamily programs.' },
  { icon: ic.student, name: 'Mezzanine Financing', desc: 'Additional leverage that sits behind the senior debt.' },
  { icon: ic.office, name: 'Junior Mortgages', desc: 'Second-position financing to unlock equity in the asset.' },
  { icon: ic.bridge, name: 'A/B Notes', desc: 'Tranched structures that match risk to the right capital source.' },
  { icon: ic.retail, name: 'Preferred Equity, GP & LP', desc: 'Equity solutions for sponsors and partners on larger projects.' },
  { icon: ic.cmhc, name: 'Credit Enhancement', desc: 'Strengthening the deal so lenders can say yes with confidence.' },
];

// PLACEHOLDER imagery — stock photos per asset class; swap for client shots.
const assetClasses = [
  { name: 'Retail', img: '/services/finance-01.jpg' },
  { name: 'Multifamily (including CMHC)', img: '/services/finance-02.jpg' },
  { name: 'Office', img: '/services/finance-03.jpg' },
  { name: 'Industrial', img: '/services/finance-04.jpg' },
  { name: 'Hospitality', img: '/services/finance-05.jpg' },
  { name: 'Retirement Housing', img: '/services/finance-06.jpg' },
  { name: 'Student Housing', img: '/services/finance-07.jpg' },
  { name: 'Self Storage', img: '/services/finance-08.jpg' },
  { name: 'Mixed Use', img: '/services/finance-09.jpg' },
  { name: 'Land & Development', img: '/services/finance-10.jpg' },
  { name: 'Special Purpose', img: '/services/finance-11.jpg' },
];

const steps = [
  { title: 'Tell us about your deal.', body: 'Share the property, the plan, and what matters most, rate, leverage, structure, or speed.' },
  { title: 'We assess and strategize.', body: 'We pressure-test the numbers and identify the right path before anyone commits.' },
  { title: 'We build your case.', body: "We package a complete, bank-quality underwriting file that answers the questions before they're asked." },
  { title: 'We connect with the right people.', body: 'We take it to the lenders most likely to fund it, through relationships built over decades.' },
  { title: 'You close with confidence.', body: 'Clear terms, no surprises, no hidden fees.' },
];

// PLACEHOLDER transactions — fictional deals; replace with real closings.
const deals = [
  { amount: '$14.2M', asset: 'Multifamily', type: 'CMHC Construction', location: 'Toronto, ON', note: 'Insured leverage secured before the rate lock expired.' },
  { amount: '$8.6M', asset: 'Industrial', type: 'Bridge Financing', location: 'Vancouver, BC', note: 'Closed in 21 days to beat a competing offer.' },
  { amount: '$22.5M', asset: 'Mixed Use', type: 'Construction Loan', location: 'Markham, ON', note: '' },
  { amount: '$5.4M', asset: 'Retail', type: 'Conventional Term', location: 'Mississauga, ON', note: 'Refinanced at 75% LTV on stabilized income.' },
  { amount: '$31.0M', asset: 'Student Housing', type: 'CMHC Insured', location: 'Waterloo, ON', note: '' },
  { amount: '$11.8M', asset: 'Self Storage', type: 'A/B Notes', location: 'Burnaby, BC', note: 'Tranched structure matched two capital sources.' },
];
---
<BaseLayout
  title="Services — FT Funding Direct Capital"
  description="Commercial financing for every stage: construction, land & development, bridge, CMHC insured, mezzanine, and more — across every asset class in Canada."
>
  <!-- HERO — transparent nav over the image, same as About -->
  <section class="hero hero--services">
    <Nav />
    <div class="hero-body">
      <div class="hero-inner" data-reveal-stagger>
        <h1 data-reveal>Financing for every stage<br class="br-tablet"> of your <span class="gold">project.</span></h1>
        <p data-reveal>From land to lease-up, acquisition to refinance, we structure commercial financing across every asset class, and we package it to the standard lenders expect.</p>
        <a href="/contact" class="btn btn-outline" data-reveal>Request a Quote</a>
      </div>
    </div>
  </section>

  <!-- WHAT WE DO — 10 services, divider rows in 2 columns -->
  <section class="svcdo-band">
    <div class="wrap">
      <div class="sec-head" data-reveal>
        <div class="eyebrow">What We Do</div>
        <h2>The full lifecycle of commercial real estate <span class="gold">financing.</span></h2>
        <p class="intro-copy svcdo-intro">Whatever the stage, whatever the structure, we arrange the capital that fits. One point of contact. Access to lenders across Canada.</p>
      </div>
      <div class="sv-grid" data-reveal-stagger>
        {services.map((s) => (
          <div class="sv-row" data-reveal>
            <span class="sv-icon" style={`--icon:url('${s.icon}')`} aria-hidden="true"></span>
            <div>
              <h3 class="sv-name">{s.name}</h3>
              <p>{s.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- WHAT WE FINANCE — word-wall showcase: the active name is gold and its
       related photo cross-fades in behind a navy overlay; autoplays 3s per
       asset, hover (desktop) / tap (touch) takes over, loop resumes after -->
  <section class="finance-band">
    <div class="fin-bgs" aria-hidden="true">
      {assetClasses.map((a) => (
        <div class="fin-bg" style={`background-image:url('${a.img}')`}></div>
      ))}
    </div>
    <div class="fin-overlay" aria-hidden="true"></div>
    <div class="wrap">
      <div class="sec-head" data-reveal>
        <div class="eyebrow">What We Finance</div>
        <h2>Every commercial<br class="br-sm"> <span class="gold">asset class.</span></h2>
      </div>
      <div class="asset-flow" data-reveal-stagger>
        {assetClasses.map((a) => (
          <button class="af-item" type="button" data-reveal>{a.name}</button>
        ))}
      </div>
    </div>
  </section>

  <!-- HOW WE WORK — statement left, 5 numbered steps right -->
  <section class="process-band">
    <div class="wrap process">
      <div class="process-text">
        <div class="eyebrow" data-reveal>How We Work</div>
        <h2 data-reveal>You Ask. <span class="gold">We Deliver.</span></h2>
        <p class="intro-copy process-intro" data-reveal>Our process is built around one idea: do the heavy lifting so you don't have to. We underwrite your deal to bank quality before it ever reaches a lender, which is why we deliver faster and cleaner.</p>
      </div>
      <div class="steps" data-reveal-stagger>
        {steps.map((s, i) => (
          <div class="step" data-reveal>
            <div class="step-num">{String(i + 1).padStart(2, '0')}</div>
            <div class="step-body">
              <h3>{s.title}</h3>
              <p>{s.body}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- NOTABLE TRANSACTIONS — infinite data-card slider -->
  <section class="deals-band">
    <div class="wrap">
      <div class="team-head">
        <div class="sec-head" data-reveal>
          <div class="eyebrow">Proof of Work</div>
          <h2>Deals we've closed across <span class="gold">Canada.</span></h2>
          <!-- PLACEHOLDER link — point at the transactions/blog page when it exists -->
          <a href="/resources" class="btn btn-outline deals-btn">View Recent Transactions</a>
        </div>
        <div class="team-nav" data-reveal>
          <button class="team-arrow prev" type="button" aria-label="Previous transactions">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="19" y1="12" x2="5" y2="12"></line>
              <polyline points="12 19 5 12 12 5"></polyline>
            </svg>
          </button>
          <button class="team-arrow next" type="button" aria-label="Next transactions">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="5" y1="12" x2="19" y2="12"></line>
              <polyline points="12 5 19 12 12 19"></polyline>
            </svg>
          </button>
        </div>
      </div>

      <div class="team-slider" data-reveal>
        <div class="team-track">
          {/* Deals rendered twice → the slider loops seamlessly. */}
          {[...deals, ...deals].map((d) => (
            <article class="deal-card">
              <div class="deal-amount">{d.amount}</div>
              <hr />
              <div class="deal-row"><div class="k">Asset Class</div><div class="v">{d.asset}</div></div>
              <div class="deal-row"><div class="k">Financing Type</div><div class="v">{d.type}</div></div>
              <div class="deal-row"><div class="k">Location</div><div class="v">{d.location}</div></div>
              {d.note && <p class="deal-note">{d.note}</p>}
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- CTA BANNER -->
  <section class="cta-band">
    <div class="wrap">
      <h2 data-reveal>Tell us what you're <span class="gold">working on.</span></h2>
      <a href="/contact" class="btn btn-outline" data-reveal>Get Your Free Consultation</a>
    </div>
  </section>

  <script>
  // Deals slider: same infinite-loop stepping as the About team slider
  // (cards rendered twice; snaps are settled before any new interaction).
  const band = document.querySelector('.deals-band');
  const slider = band?.querySelector('.team-slider');
  const track = slider?.querySelector('.team-track') as HTMLElement | null;
  const prev = band?.querySelector('.team-arrow.prev') as HTMLButtonElement | null;
  const next = band?.querySelector('.team-arrow.next') as HTMLButtonElement | null;

  if (slider && track && prev && next) {
    const tr = track;
    const cards = tr.querySelectorAll('.deal-card') as NodeListOf<HTMLElement>;
    const ORIGINALS = cards.length / 2;
    const MOVE_MS = 900;
    let index = 0;

    const step = () =>
      cards.length > 1 ? cards[1].offsetLeft - cards[0].offsetLeft : cards[0].offsetWidth;

    const setX = (animate: boolean) => {
      tr.style.transition = animate ? `transform ${MOVE_MS}ms ease` : 'none';
      tr.style.transform = `translateX(-${index * step()}px)`;
    };

    let snap: (() => void) | null = null;

    const finishSnap = () => {
      if (!snap) return;
      tr.removeEventListener('transitionend', snap);
      snap = null;
      index -= ORIGINALS;
      setX(false);
      void tr.offsetWidth;
    };

    const stepForward = () => {
      finishSnap();
      index++;
      setX(true);
      if (index >= ORIGINALS) {
        snap = () => { snap = null; index -= ORIGINALS; setX(false); };
        tr.addEventListener('transitionend', snap, { once: true });
      }
    };

    const stepBack = () => {
      finishSnap();
      if (index === 0) {
        index = ORIGINALS;
        setX(false);
        void tr.offsetWidth;
      }
      index--;
      setX(true);
    };

    // Auto-advance — the homepage slider cadence: a step every 5s, pause on
    // hover (resume 2s after the pointer leaves). Arrow clicks hold the
    // autoplay for 5s; if the pointer is still on the slider when the hold
    // ends, the hover pause carries on until 2s after it leaves.
    const STEP_MS = 5000;
    const RESUME_MS = 2000;
    const CLICK_HOLD_MS = 5000;
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    let timer: ReturnType<typeof setInterval> | null = null;
    let resume: ReturnType<typeof setTimeout> | null = null;
    let hovering = false;
    let clickHold = 0;          // timestamp until which the click pause runs

    const stop = () => { if (timer) clearInterval(timer); timer = null; };
    const start = () => { stop(); if (!reduce) timer = setInterval(stepForward, STEP_MS); };

    const pauseByClick = () => {
      stop();
      if (resume) clearTimeout(resume);
      if (reduce) return;
      clickHold = performance.now() + CLICK_HOLD_MS;
      resume = setTimeout(() => {
        if (!hovering) { stepForward(); start(); }   // still hovered → hover rules own it
      }, CLICK_HOLD_MS);
    };

    next.addEventListener('click', () => { stepForward(); pauseByClick(); });
    prev.addEventListener('click', () => { stepBack(); pauseByClick(); });

    if (!reduce) {
      // Pause region covers the arrows too (they sit outside the slider box).
      const zones = [slider, band?.querySelector('.team-nav')].filter(Boolean) as Element[];
      zones.forEach((zone) => {
        zone.addEventListener('mouseenter', () => {
          hovering = true;
          if (resume) clearTimeout(resume);
          stop();
        });
        zone.addEventListener('mouseleave', () => {
          hovering = false;
          if (resume) clearTimeout(resume);
          // Honour whatever remains of a click hold; never less than 2s.
          const delay = Math.max(RESUME_MS, clickHold - performance.now());
          resume = setTimeout(() => { stepForward(); start(); }, delay);
        });
      });
    }

    window.addEventListener('resize', () => { finishSnap(); setX(false); });
    window.addEventListener('load', () => setX(false));
    start();
  }

  // What We Finance showcase: 3s sequential autoplay through the asset names;
  // the active name golds and its photo cross-fades in. Desktop hover takes
  // over an item (loop resumes from it on leave); tap does the same on touch.
  const finBand = document.querySelector('.finance-band');
  const finItems = finBand?.querySelectorAll('.af-item') as NodeListOf<HTMLButtonElement> | undefined;
  const finBgs = finBand?.querySelectorAll('.fin-bg') as NodeListOf<HTMLElement> | undefined;

  if (finBand && finItems && finBgs && finItems.length && finBgs.length === finItems.length) {
    const items = finItems;
    const bgs = finBgs;
    const HOLD_MS = 3800;   /* 200ms moved into the longer cross-fade */
    const reduceFin = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    let cur = 0;
    let finTimer: ReturnType<typeof setInterval> | null = null;

    // The incoming photo is raised to the top of the stack so every switch is
    // a fade-IN over the old image (otherwise backward jumps read as a slow
    // top-layer fade-out and feel different from forward auto-steps). BUT a
    // layer that is still mid-fade keeps its position — re-raising a partly
    // visible layer changes the composite instantly and shows as a flash.
    let zTop = 1;
    const setActive = (i: number) => {
      cur = ((i % items.length) + items.length) % items.length;
      items.forEach((el, j) => el.classList.toggle('active', j === cur));
      bgs.forEach((el, j) => {
        if (j === cur && parseFloat(getComputedStyle(el).opacity) < 0.05) {
          el.style.zIndex = String(++zTop);
        }
        el.classList.toggle('active', j === cur);
      });
    };

    const finStop = () => { if (finTimer) clearInterval(finTimer); finTimer = null; };
    const finStart = () => { finStop(); if (!reduceFin) finTimer = setInterval(() => setActive(cur + 1), HOLD_MS); };

    const finCanHover = window.matchMedia('(hover: hover)').matches;
    items.forEach((el, i) => {
      // Hover claims the item and parks the loop (desktop).
      el.addEventListener('mouseenter', () => { finStop(); setActive(i); });
      // Tap claims it and keeps the loop running from there (touch). On
      // hover devices a click behaves like the hover: parked until leave.
      el.addEventListener('click', () => {
        setActive(i);
        if (finCanHover) finStop(); else finStart();
      });
    });

    // Pointer leaves the word-wall → resume from the current item.
    finBand.querySelector('.asset-flow')?.addEventListener('mouseleave', () => finStart());

    // Hide the separator dot on each line's LAST name — a wrapped flex row
    // can't be detected in CSS, so compare row positions per item.
    const markRowEnds = () => {
      items.forEach((el, i) => {
        const nextEl = items[i + 1];
        el.classList.toggle('no-dot', !nextEl || nextEl.offsetTop !== el.offsetTop);
      });
    };
    markRowEnds();
    window.addEventListener('resize', markRowEnds);
    window.addEventListener('load', markRowEnds);   // re-measure once fonts settle

    setActive(0);
    finStart();
  }
  </script>
</BaseLayout>
