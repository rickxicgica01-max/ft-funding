---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';

// Sources-of-Capital logo rows. Three fixed groups, each used twice across the
// 6 rows, every row repeated enough times to scroll seamlessly.
type Logo = { name: string; src: string; w: number; h: number };
const logoGroups: Logo[][] = [
  [ { name: 'BMO', src: '/home/logos/logo-bmo.png', w: 399, h: 139 },
    { name: 'CIBC', src: '/home/logos/logo-cibc.png', w: 400, h: 103 },
    { name: 'MCAP', src: '/home/logos/logo-mcap.png', w: 400, h: 130 } ],
  [ { name: 'TD Asset Management', src: '/home/logos/logo-td.png', w: 400, h: 92 },
    { name: 'iA Financial Group', src: '/home/logos/logo-ia.png', w: 398, h: 218 },
    { name: 'Home Trust', src: '/home/logos/logo-hometrust.png', w: 400, h: 87 } ],
  [ { name: 'RBC', src: '/home/logos/logo-rbc.png', w: 170, h: 222 },
    { name: 'Equitable Bank', src: '/home/logos/logo-equitable.png', w: 395, h: 57 },
    { name: 'Desjardins', src: '/home/logos/logo-desjardins.png', w: 396, h: 85 } ],
];
// 6 rows total — the 3 groups, each shown twice (directions alternate).
const logoRows = [0, 1, 2, 0, 1, 2];

// Every logo drawn to the same AREA (w*h), keeping its own ratio → balanced sizes.
// LOGO_AREA is tuned so ~5 logos show per row. COPIES even so -50% loops seamlessly.
// LOGO_AREA_T is the smaller tablet/mobile area (~80% linear scale), applied via
// per-logo CSS vars so each keeps its own ratio (see the .logo-chip media rule).
const LOGO_AREA = 6000, LOGO_AREA_T = 3800, LOGO_GAP = 50, SPEED = 55, COPIES = 8;
const sized = (area: number, l: Logo) => {
  const r = l.w / l.h;
  return { w: Math.round(Math.sqrt(area * r)), h: Math.round(Math.sqrt(area / r)) };
};
const logoDisp = (l: Logo) => sized(LOGO_AREA, l);
const logoDispT = (l: Logo) => sized(LOGO_AREA_T, l);
const repeatGroup = (g: number) => Array.from({ length: COPIES }, () => logoGroups[g]).flat();
// Width of one group at display size, then per-row duration so every row scrolls
// at the same px/s regardless of its logos' widths.
const groupWidth = (g: number) => logoGroups[g].reduce((s, l) => s + logoDisp(l).w + LOGO_GAP, 0);
const rowDuration = (g: number) => ((groupWidth(g) * COPIES) / 2 / SPEED).toFixed(1);
---
<BaseLayout
  title="FT Funding Direct Capital — One Stop Commercial Lending Brokerage"
>
  <!-- HERO -->
  <section class="hero">
    <Nav />

    <div class="hero-body">
      <div class="hero-inner" data-reveal-stagger>
        <h1 data-reveal>One Stop Commercial Lending Brokerage</h1>
        <p data-reveal>We arrange commercial financing for real estate investors, developers, and business owners across Toronto, GTA and Greater Vancouver.</p>
        <a href="/#contact" class="btn btn-outline" data-reveal>Talk to an Expert Today</a>
      </div>

      <!-- Rates card -->
      <aside class="rates">
        <div class="label">Today's Rates</div>
        <div class="date">Apr 7, 2026</div>
        <hr>
        <div class="rates-grid">
          <div class="rate"><div class="k">RBC Prime Rate</div><div class="v"><span class="num-wrap"><span class="num" data-count="4.45">4.45</span>%</span></div></div>
          <div class="rate"><div class="k">5 Year GOC</div><div class="v"><span class="arr up"></span><span class="num-wrap"><span class="num" data-count="3.49">3.49</span>%</span></div></div>
          <div class="rate"><div class="k">5 Year GOC</div><div class="v"><span class="arr up"></span><span class="num-wrap"><span class="num" data-count="3.13">3.13</span>%</span></div></div>
          <div class="rate"><div class="k">10 Year CMB</div><div class="v"><span class="arr up"></span><span class="num-wrap"><span class="num" data-count="3.89">3.89</span>%</span></div></div>
          <div class="rate"><div class="k">5 Year CMB</div><div class="v"><span class="arr up"></span><span class="num-wrap"><span class="num" data-count="3.39">3.39</span>%</span></div></div>
          <div class="rate"><div class="k">CORRA 3 Mo Term</div><div class="v"><span class="arr down"></span><span class="num-wrap"><span class="num" data-count="2.28">2.28</span>%</span></div></div>
          <div class="rate"><div class="k">CORRA 1 Mo Term</div><div class="v"><span class="arr down"></span><span class="num-wrap"><span class="num" data-count="2.27">2.27</span>%</span></div></div>
        </div>
        <p class="foot">We arrange commercial financing for real estate investors, developers, and business owners across Toronto, GTA and Greater Vancouver.</p>
      </aside>
    </div>
  </section>

  <!-- LENDING SOLUTIONS -->
  <section id="services" class="svc-section">
    <div class="wrap svc-grid" data-reveal-stagger>
      <div class="sec-head svc-text" data-reveal>
        <div class="eyebrow">Our Services</div>
        <h2>Our Lending <span class="gold">Solutions</span></h2>
        <p class="intro-copy">Lorem Ipsum is simply dummy text of the printing and typesetting industry.</p>
        <a href="/services" class="btn btn-outline">View All Loan Services</a>
      </div>
      <article class="svc-card" style="--img:url('/home/home-card-bg-01.jpg')" data-reveal>
        <img class="svc-icon" src="/home/home-icon-construction.png" alt="" />
        <h3>Construction<br>Loans</h3>
      </article>
      <article class="svc-card" style="--img:url('/home/home-card-bg-02.jpg')" data-reveal>
        <img class="svc-icon" src="/home/home-icon-bridge.png" alt="" />
        <h3>Bridge<br>Financing</h3>
      </article>
      <article class="svc-card" style="--img:url('/home/home-card-bg-03.jpg')" data-reveal>
        <img class="svc-icon" src="/home/home-icon-cmhc.png" alt="" />
        <h3>CMHC Insured<br>&amp; Construction</h3>
      </article>
    </div>
  </section>

  <!-- ASSET CLASSES -->
  <section id="asset-classes" class="svc-section svc-section--dark">
    <div class="wrap svc-grid" data-reveal-stagger>
      <div class="sec-head svc-text" data-reveal>
        <div class="eyebrow">Our Services</div>
        <h2>Asset <span class="gold">Classes</span></h2>
        <p class="intro-copy">Lorem Ipsum is simply dummy text of the printing and typesetting industry.</p>
        <a href="/services" class="btn btn-outline">View All Services</a>
      </div>
      <article class="svc-card svc-card--gold" style="--img:url('/home/home-card-bg-04.jpg')" data-reveal>
        <img class="svc-icon" src="/home/home-icon-retail.png" alt="" />
        <h3>Retail</h3>
      </article>
      <article class="svc-card svc-card--gold" style="--img:url('/home/home-card-bg-05.jpg')" data-reveal>
        <img class="svc-icon" src="/home/home-icon-office.png" alt="" />
        <h3>Office</h3>
      </article>
      <article class="svc-card svc-card--gold" style="--img:url('/home/home-card-bg-06.jpg')" data-reveal>
        <img class="svc-icon" src="/home/home-icon-student.png" alt="" />
        <h3>Student<br>Housing</h3>
      </article>
    </div>
  </section>

  <!-- SOURCES OF CAPITAL -->
  <section id="sources" class="capital-band">
    <div class="capital-logos" aria-hidden="true">
      {logoRows.map((g, i) => (
        <div class:list={["logo-row", { rev: i % 2 === 1 }]}>
          <div class="logo-track" style={`animation-duration:${rowDuration(g)}s`}>
            {repeatGroup(g).map((l) => {
              const d = logoDisp(l);
              const t = logoDispT(l);
              return <img class="logo-chip" src={l.src} alt={l.name} width={d.w} height={d.h} style={`--wt:${t.w}px;--ht:${t.h}px`} draggable={false} />;
            })}
          </div>
        </div>
      ))}
    </div>
    <div class="capital-panel">
      <div class="capital-content" data-reveal>
        <h2>Sources of <span class="gold">Capital</span></h2>
        <ul class="capital-list">
          <li>Canadian Banks</li>
          <li>International Banks</li>
          <li>Insurance Companies (Domestic &amp; Foreign)</li>
          <li>Pension Funds</li>
          <li>Credit Unions</li>
          <li>CMHC</li>
          <li>Private Equity &amp; Debt Funds</li>
          <li>Mortgage Investment Corporations (MICs)</li>
          <li>CMBS Conduits</li>
          <li>Family Offices</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- WHY FUNDING DIRECT -->
  <section id="about" class="band-navy why-band">
    <div class="wrap why">
      <div class="why-text">
        <h2 data-reveal>Why<br><span class="gold">Funding Direct</span></h2>
        <p class="intro-copy" data-reveal>We combine deep market expertise with a client-first approach to deliver exceptional results for Canadian businesses.</p>
        <a href="/contact" class="btn btn-outline" data-reveal>Contact Us Today</a>
      </div>
      <div class="reasons" data-reveal-stagger>
        <div class="row" data-reveal><span class="row-arrow" aria-hidden="true"></span><h3>Responsiveness</h3><p>Direct access to senior brokers, not call centres. We respond within hours, not days.</p></div>
        <div class="row" data-reveal><span class="row-arrow" aria-hidden="true"></span><h3>Speed</h3><p>Conditional approvals in 48 hours. Our streamlined process gets you funded faster.</p></div>
        <div class="row" data-reveal><span class="row-arrow" aria-hidden="true"></span><h3>Reliability</h3><p>Built on 15+ years of successful deals. We deliver on our commitments, every time.</p></div>
        <div class="row" data-reveal><span class="row-arrow" aria-hidden="true"></span><h3>Simplicity</h3><p>One point of contact from application to closing. No handoffs, no confusion.</p></div>
        <div class="row" data-reveal><span class="row-arrow" aria-hidden="true"></span><h3>Professionalism</h3><p>Institutional-grade service for every client. We treat your deal like our own.</p></div>
      </div>
    </div>
  </section>

  <!-- TESTIMONIALS -->
  <section class="test-band">
    <img class="test-ft" src="/home/testimonial-ft.png" alt="" aria-hidden="true" />
    <div class="wrap">
      <div class="team-head">
        <div class="sec-head" data-reveal>
          <div class="eyebrow">Client Stories</div>
          <h2>What Our Clients Say</h2>
        </div>
        <div class="team-nav" data-reveal>
          <button class="team-arrow prev" type="button" aria-label="Previous testimonials">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="19" y1="12" x2="5" y2="12"></line>
              <polyline points="12 19 5 12 12 5"></polyline>
            </svg>
          </button>
          <button class="team-arrow next" type="button" aria-label="Next testimonials">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="5" y1="12" x2="19" y2="12"></line>
              <polyline points="12 5 19 12 12 19"></polyline>
            </svg>
          </button>
        </div>
      </div>
      <div class="test-slider" data-reveal>
        <div class="test-track">
          {Array.from({ length: 10 }).map(() => (
            <article class="tcard">
              <div class="stars">★★★★★</div>
              <blockquote>"Working with FT Funding Direct was the first time I felt like the broker was actually fighting for my deal. They came back with terms I didn't think were possible."</blockquote>
              <div class="who">
                <div class="ava"></div>
                <div>
                  <div class="name">Client Name</div>
                  <div class="title">Client Title / Company</div>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- CONSULTATION -->
  <section id="contact" class="consult-band">
    <div class="wrap consult">
      <div>
        <h2 data-reveal>Book a<br><span class="gold">Consultation</span></h2>
      </div>
      <div>
        <form method="POST" action="https://formspree.io/f/mqeoyvad" data-form
          data-success="Thank you — your request has been sent. We'll be in touch shortly." data-reveal>
          <input type="hidden" name="_subject" value="Homepage Consultation — FT Funding website">
          <input type="hidden" name="source" value="Homepage Consultation">
          <div class="formgrid">
            <div class="field"><input type="text" name="name" placeholder="Your Name" autocomplete="name" required></div>
            <div class="field"><input type="email" name="email" placeholder="Your Email" autocomplete="email" required></div>
            <div class="field full"><textarea name="message" placeholder="Your Message" rows="3" required></textarea></div>
          </div>
          <input type="text" name="_gotcha" class="hp" tabindex="-1" autocomplete="off" aria-hidden="true">
          <button class="btn btn-outline" type="submit">Get Your Free Consultation</button>
        </form>
      </div>
    </div>
  </section>

  <script>
  // Testimonials: the shared slider engine (same as the team/deals sliders) —
  // infinite loop in both directions, 5s auto-step, hover pause with 2s
  // resume, arrow clicks hold the autoplay for 5s.
  const slider = document.querySelector('.test-slider');
  const track = slider?.querySelector('.test-track') as HTMLElement | null;
  const prev = document.querySelector('.team-arrow.prev') as HTMLButtonElement | null;
  const next = document.querySelector('.team-arrow.next') as HTMLButtonElement | null;

  if (slider && track && prev && next) {
    const tr = track;
    const cards = tr.querySelectorAll('.tcard') as NodeListOf<HTMLElement>;
    const ORIGINALS = cards.length / 2;   // slides rendered twice for the loop
    const MOVE_MS = 900;
    let index = 0;

    const step = () =>
      cards.length > 1 ? cards[1].offsetLeft - cards[0].offsetLeft : cards[0].offsetWidth;

    const setX = (animate: boolean) => {
      tr.style.transition = animate ? `transform ${MOVE_MS}ms ease` : 'none';
      tr.style.transform = `translateX(-${index * step()}px)`;
    };

    let snap: (() => void) | null = null;

    const finishSnap = () => {
      if (!snap) return;
      tr.removeEventListener('transitionend', snap);
      snap = null;
      index -= ORIGINALS;
      setX(false);
      void tr.offsetWidth;
    };

    const stepForward = () => {
      finishSnap();
      index++;
      setX(true);
      if (index >= ORIGINALS) {
        snap = () => { snap = null; index -= ORIGINALS; setX(false); };
        tr.addEventListener('transitionend', snap, { once: true });
      }
    };

    const stepBack = () => {
      finishSnap();
      if (index === 0) {
        index = ORIGINALS;
        setX(false);
        void tr.offsetWidth;
      }
      index--;
      setX(true);
    };

    const STEP_MS = 5000;
    const RESUME_MS = 2000;
    const CLICK_HOLD_MS = 5000;
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    let timer: ReturnType<typeof setInterval> | null = null;
    let resume: ReturnType<typeof setTimeout> | null = null;
    let hovering = false;
    let clickHold = 0;

    const stop = () => { if (timer) clearInterval(timer); timer = null; };
    const start = () => { stop(); if (!reduce) timer = setInterval(stepForward, STEP_MS); };

    const pauseByClick = () => {
      stop();
      if (resume) clearTimeout(resume);
      if (reduce) return;
      clickHold = performance.now() + CLICK_HOLD_MS;
      resume = setTimeout(() => {
        if (!hovering) { stepForward(); start(); }
      }, CLICK_HOLD_MS);
    };

    // Click cooldown: ignore clicks while a move is in flight, so spamming
    // the arrows can't outrun the 900ms slide.
    let busy = false;
    const cooldown = () => { busy = true; setTimeout(() => { busy = false; }, MOVE_MS); };

    next.addEventListener('click', () => { if (busy) return; stepForward(); pauseByClick(); cooldown(); });
    prev.addEventListener('click', () => { if (busy) return; stepBack(); pauseByClick(); cooldown(); });

    if (!reduce) {
      const zones = [slider, document.querySelector('.team-nav')].filter(Boolean) as Element[];
      zones.forEach((zone) => {
        zone.addEventListener('mouseenter', () => {
          hovering = true;
          if (resume) clearTimeout(resume);
          stop();
        });
        zone.addEventListener('mouseleave', () => {
          hovering = false;
          if (resume) clearTimeout(resume);
          const delay = Math.max(RESUME_MS, clickHold - performance.now());
          resume = setTimeout(() => { stepForward(); start(); }, delay);
        });
      });
    }

    window.addEventListener('resize', () => { finishSnap(); setX(false); });
    window.addEventListener('load', () => setX(false));
    start();
  }

  // Consultation message: grow with the number of rows typed (never below its
  // initial height), so the gap to the underline isn't a fixed px.
  const ta = document.querySelector('.consult textarea') as HTMLTextAreaElement | null;
  if (ta) {
    const minH = ta.offsetHeight;
    const grow = () => {
      ta.style.height = 'auto';
      ta.style.height = Math.max(ta.scrollHeight, minH) + 'px';
    };
    ta.addEventListener('input', grow);
  }
  </script>
</BaseLayout>
