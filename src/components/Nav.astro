---
// Shared site navigation. Pass `solid` on inner pages that have no hero image
// behind the bar, so it renders as a sticky navy bar instead of transparent.
const { solid = false } = Astro.props;

// Normalize the current path (drop trailing slash) so the active link lights up
// regardless of how Astro emits the route.
const path = Astro.url.pathname.replace(/\/+$/, '') || '/';

const links = [
  { href: '/about', label: 'About' },
  { href: '/services', label: 'Services' },
  { href: '/resources', label: 'Resources' },
  { href: '/contact', label: 'Contact' },
];

// The mobile/tablet dropdown adds the CTA as a 5th row, styled like the others.
// `cta` keeps it out of the active-state matching — it shares /contact with
// the Contact link, which would otherwise highlight both on that page.
const menuItems = [...links.map((l) => ({ ...l, cta: false })), { href: '/contact', label: 'Book A Consultation', cta: true }];
---
<header class:list={["nav-wrap", { "nav-solid": solid }]}>
  <nav class="nav">
    <a href="/" class="logo">
      <img src="/navigation/site-logo.png" alt="FT Funding Direct Capital" />
    </a>
    <div class="nav-links">
      {links.map(({ href, label }) => (
        <a href={href} class:list={{ active: path === href }} aria-current={path === href ? 'page' : undefined}>{label}</a>
      ))}
    </div>
    <a href="/contact" class="btn btn-solid nav-cta">Book A Consultation</a>
    <button class="nav-toggle" type="button" aria-label="Toggle menu" aria-expanded="false" aria-controls="nav-menu">
      <span></span><span></span><span></span>
    </button>
  </nav>

  <div class="nav-menu" id="nav-menu">
    {menuItems.map(({ href, label, cta }) => (
      <a href={href} class:list={["nav-menu-item", { active: !cta && path === href }]} aria-current={!cta && path === href ? 'page' : undefined}>{label}</a>
    ))}
  </div>
</header>

<script>
  // Slide the dropdown open/closed (max-height transition in global.css).
  // scrollHeight gives the real content height even while collapsed, so the
  // transition always travels the exact distance — smooth both ways.
  const toggle = document.querySelector('.nav-toggle');
  const menu = document.getElementById('nav-menu');
  if (toggle && menu) {
    toggle.addEventListener('click', () => {
      const open = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!open));
      menu.classList.toggle('open', !open);
      menu.style.maxHeight = open ? '0' : menu.scrollHeight + 'px';
    });
  }
</script>
