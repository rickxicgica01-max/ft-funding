---
// Shared site footer used on every page.
const year = new Date().getFullYear();
---
<footer>
  <div class="wrap">
    <div class="foot-top">
      <div class="foot-brand">
        <a href="/" class="logo"><span class="mark">◆</span> FT Funding Direct Capital</a>
        <div class="deliver">You Ask. <span>We Deliver.</span></div>
        <div class="foot-social"><a href="#">f</a><a href="#">in</a><a href="#">◎</a></div>
      </div>
      <div class="foot-col">
        <h4>Quick Links</h4>
        <ul>
          <li><a href="/about">About Us</a></li>
          <li><a href="/services">Services</a></li>
          <li><a href="/resources">Resources</a></li>
          <li><a href="/contact">Contact Us</a></li>
        </ul>
      </div>
      <div class="foot-col">
        <h4>Office</h4>
        <p>7181 Woodbine Ave #108, Markham, ON L3R 1A3</p>
        <h4 style="margin-top:24px;">Contact</h4>
        <p>+647-123-4567</p>
        <p>info@FTfunding.com</p>
      </div>
      <div class="foot-col">
        <h4>Newsletter</h4>
        <div class="news-input">
          <input type="email" placeholder="Enter Your Email">
          <button type="button">→</button>
        </div>
      </div>
    </div>
    <div class="foot-bottom">
      <span>© {year} FT Funding Direct Capital all rights reserved.</span>
      <span>Design &amp; developed by CGICA.</span>
    </div>
  </div>
</footer>
